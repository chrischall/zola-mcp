# Required: long-lived refresh token (~1 year). Copy value of 'usr' cookie from Zola in DevTools.
ZOLA_REFRESH_TOKEN=your_usr_cookie_value_here

# Optional: short-lived session token (30 min). Copy value of 'us' cookie from Zola in DevTools.
# Required only if auto-refresh fails. Update when you see a session-expired error.
ZOLA_SESSION_TOKEN=your_us_cookie_value_here
