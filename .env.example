# Required: mobile refresh token JWT (~1 year lifetime).
# Run ./scripts/setup-auth.sh to capture from the Zola iOS app via mitmproxy.
ZOLA_REFRESH_TOKEN=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Required for seating tools: your Zola wedding account ID.
# Captured automatically by setup-auth.sh.
ZOLA_ACCOUNT_ID=1234567

# Optional: short-lived session token (30 min). Skips the initial refresh call.
# Not needed if ZOLA_REFRESH_TOKEN is set — the server auto-refreshes.
ZOLA_SESSION_TOKEN=
